generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  name         String
  avatar       String?
  role         String   @default("influencer")
  isVerified   Boolean  @default(false)
  followerCount Int     @default(0)
  platformData String?
  organicScore  Float   @default(0)
  engagementRate Float  @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  campaigns    CampaignSwipe[]
  coupons      Coupon[]
  payments     Payment[]
}

model Campaign {
  id              String   @id @default(uuid())
  brandId         String
  title           String
  description     String
  category        String
  imageUrl        String?
  couponTotal     Int
  couponUsed      Int      @default(0)
  commissionRate  Float    @default(70)
  startDate       DateTime
  endDate         DateTime
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  brand           Brand    @relation(fields: [brandId], references: [id])
  swipes          CampaignSwipe[]
  coupons         Coupon[]
  payments        Payment[]
}

model Brand {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String
  name        String
  logo        String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  campaigns   Campaign[]
}

model CampaignSwipe {
  id            String   @id @default(uuid())
  campaignId    String
  influencerId  String
  direction     String
  createdAt     DateTime @default(now())
  campaign      Campaign @relation(fields: [campaignId], references: [id])
  influencer    User     @relation(fields: [influencerId], references: [id])
  coupon        Coupon?  @relation(fields: [couponId], references: [id])
  couponId      String?
}

model Coupon {
  id            String   @id @default(uuid())
  campaignId    String
  code          String
  maxUses       Int
  currentUses   Int      @default(0)
  assignedTo    String?
  assignedAt    DateTime?
  status        String   @default("available")
  createdAt     DateTime @default(now())
  campaign      Campaign @relation(fields: [campaignId], references: [id])
  influencer    User?    @relation(fields: [assignedTo], references: [id])
  swipes        CampaignSwipe[]
}

model Payment {
  id            String   @id @default(uuid())
  influencerId  String
  campaignId    String?
  couponId      String?
  amount        Float
  platformFee   Float
  netAmount     Float
  status        String   @default("pending")
  createdAt     DateTime @default(now())
  paidAt        DateTime?
  influencer    User     @relation(fields: [influencerId], references: [id])
  campaign      Campaign? @relation(fields: [campaignId], references: [id])
}